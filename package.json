{
  "name": "mcp-web-search",
  "version": "1.0.0",
  "description": "MCP server for web search with anti-detection and LLM-optimized output",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-web-search": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "node --test --import tsx tests/**/*.test.ts",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "web-search",
    "puppeteer",
    "stealth"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "dotenv": "^16.4.5",
    "linkedom": "^0.18.13",
    "pdfjs-dist": "^6.1.200",
    "pino": "^10.3.1",
    "puppeteer": "^23.0.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-extra-plugin-user-data-dir": "^2.4.1",
    "puppeteer-extra-plugin-user-preferences": "^2.4.1",
    "robots-parser": "^3.0.1",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pino": "^7.0.4",
    "@types/turndown": "^5.0.5",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.64.0"
  }
}
