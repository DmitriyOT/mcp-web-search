# Search providers (optional - DuckDuckGo works without API keys)
SERPER_API_KEY=
BING_API_KEY=

# Anti-detect
STEALTH_ENABLED=true
HEADLESS=true
PROXY_LIST=
USER_DATA_DIR=

# Limits
MAX_RESULTS=10
MAX_CONTENT_LENGTH=8000
REQUEST_TIMEOUT=30000
CACHE_TTL=300

# Behavior
MIN_DELAY=500
MAX_DELAY=3000
MAX_CONCURRENT=2
